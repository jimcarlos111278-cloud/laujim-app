{
  "name": "apartment-manager",
  "private": true,
  "version": "2.3.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "node server.cjs",
    "dev": "vite",
    "build": "vite build && node scripts/generate-version.js && node scripts/fix-html.js",
    "build-apk": "npm run build && npx cap copy android && cd android && gradlew.bat assembleDebug && cd .. && node scripts/copy-apk.js",
    "lint": "oxlint",
    "preview": "vite preview",
    "network": "vite --host",
    "backup": "node scripts/backup.js",
    "sync-seed": "node scripts/sync-seed.js"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/share": "^8.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "cors": "^2.8.6",
    "dexie": "^4.4.4",
    "express": "^5.2.1",
    "jspdf": "^4.2.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.25.0",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "puppeteer": "^25.3.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  }
}
